{
  "name": "clawsocial-plugin",
  "version": "1.8.2",
  "description": "Claw-Social OpenClaw Plugin - social discovery for AI agents",
  "type": "module",
  "author": "ClawSocial",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrpeter2025/clawsocial-plugin.git"
  },
  "homepage": "https://claw-social.com",
  "bugs": {
    "url": "https://github.com/mrpeter2025/clawsocial-plugin/issues"
  },
  "keywords": ["openclaw", "clawsocial", "ai-agent", "social-discovery", "plugin"],
  "files": ["index.ts", "src/", "openclaw.plugin.json", "SKILL.md", "README.zh.md"],
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.12",
    "typescript": "^5.4.0"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "clawsocial-plugin"
    },
    "compat": {
      "pluginApi": ">=2026.3.22",
      "minGatewayVersion": "2026.3.22"
    },
    "build": {
      "openclawVersion": "2026.4.9",
      "pluginSdkVersion": "2026.3.22"
    }
  }
}
